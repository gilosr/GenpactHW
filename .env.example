# ── Database ──────────────────────────────────────────────────
# Default: SQLite file in project root. Override for PostgreSQL/MySQL.
# Examples:
#   sqlite:///university.db
#   postgresql://user:pass@localhost:5432/university
DATABASE_URL=sqlite:///university.db

# ── LLM Provider (pick one) ───────────────────────────────────
OPENAI_API_KEY=your-openai-api-key-here
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── LangSmith Tracing (Req 4) ─────────────────────────────────
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=your-langsmith-api-key-here
LANGSMITH_PROJECT=genpact-university-qa

# ── Config overrides (optional — defaults are in config.py) ───
# LLM__SQL_GENERATION__MODEL=gpt-4o-mini
# LLM__RETRY__MODEL=gpt-4o-mini
# LLM__ANSWER__MODEL=gpt-4o
# LLM__RELEVANCE__MODEL=gpt-4o-mini
# AGENT__MAX_RETRIES=5
# CACHE__MAX_SIZE=256
# CACHE__TTL_SECONDS=7200
# PROMPT__DOMAIN=university
# PROMPT__HUB_ENABLED=false
# PROMPT__HUB_PREFIX=genpact-university-qa
# PROMPT__HUB_TAG=production
